{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SteamSPA Targets",
  "type": "object",
  "required": ["version", "rules"],
  "properties": {
    "version": { "type": "integer" },
    "meta": {
      "type": "object",
      "properties": {
        "project":     { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/definitions/rule" }
    }
  },
  "definitions": {
    "rule": {
      "type": "object",
      "required": ["id", "title", "actions"],
      "properties": {
        "id":       { "type": "string" },
        "title":    { "type": "string" },
        "sources":  { "type": "array", "items": { "type": "string" } },
        "enabled":  { "type": "boolean", "default": true },
        "risk":     { "type": "string", "enum": ["low", "medium", "high"] },
        "confirm":  { "type": "boolean", "default": false },
        "actions":  { "type": "array", "items": { "$ref": "#/definitions/action" } }
      }
    },
    "action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "file",
            "registry-key",
            "registry-value",
            "shortcut",
            "task",
            "process",
            "service",
            "defender-exclusion-path",
            "defender-exclusion-extension"
          ]
        },
        "path":    { "type": "string" },
        "name":    { "type": "string" },
        "recurse": { "type": "boolean", "default": false }
      }
    }
  }
}
