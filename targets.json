                                      "scripts/steam.run/steam.run.002.ps1",
                                      "scripts/steam.work/steam.icu.001.ps1"
                                  ],
                      "enabled":  true,
                      "risk":  "low",
                      "actions":  [
                                      {
                                          "type":  "file",
                                          "path":  "${SteamPath}\\dwmapi.dll"
