                  {
                      "id":  "registry-steamtools",
                      "title":  "注册表 HKCU\\Software\\Valve\\Steamtools",
                      "sources":  [
                                      "scripts/steam-run.com/142785900.001.ps1",
                                      "scripts/steam-run.com/steam-run.com.001.ps1",
                                      "scripts/steam-run.com/steam-run.com.002.ps1",
